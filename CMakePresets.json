{
    "version": 5,
	"cmakeMinimumRequired": {
        "major": 3,
        "minor": 24,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "debug",
            "displayName": "Generate Ninja Makefiles for debugging",
            "description": "Sets Ninja Makefiles generator, build and install directory",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_PREFIX_PATH": "",
                "CMAKE_TOOLCHAIN_FILE": "",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/${presetName}"
            }
        },
        {
            "name": "release",
            "displayName": "Generate Ninja Makefiles for releasing",
            "description": "Sets Ninja Makefiles generator, build and install directory",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_PREFIX_PATH": "",
                "CMAKE_TOOLCHAIN_FILE": "",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/install/${presetName}"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "debug",
            "displayName": "Build debuggable target with Ninja Makefiles",
            "configurePreset": "debug",
            "configuration": "Debug",
            "targets": "all",
            "jobs": 8
        }
    ],
    "testPresets": [
        {
            "name": "benchmarks/sum",
            "description": "test benchmarks/sum/extracted.ll",
            "displayName": "",
            "configurePreset": "debug"
        }
    ]
}
